# Copia a `.env.local` y rellena los valores.

# --- OpenAI (solo servidor; no uses NEXT_PUBLIC) ---
# Necesaria para `/api/calificar/vision-omr` (segunda lectura con IA).
# Sin esta clave, la calificación sigue funcionando solo con el lector OMR en el cliente.
OPENAI_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# --- Supabase server admin (solo servidor) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- Visión CaliFacil (públicas; se inyectan en el build del cliente) ---
# Al confirmar desde cámara en vivo («Revisar y confirmar»): llamar a visión para toda la hoja.
# Por defecto activo si omites la variable. Para desactivar:
# NEXT_PUBLIC_CALIFACIL_VISION_ON_LIVE_COMMIT=false

# Tras importar o capturar imagen: segunda pasada IA sobre todas las filas (más coste API).
# Por defecto desactivado. Para activar:
# NEXT_PUBLIC_CALIFACIL_VISION_ON_FINAL=true
