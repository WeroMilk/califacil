# Copia a `.env.local` y rellena los valores.

# --- Supabase (requerido para login y datos) ---
# En Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- OpenAI (solo servidor; no uses NEXT_PUBLIC) ---
# Necesaria para `/api/calificar/vision-omr` (segunda lectura con IA).
# Sin esta clave, la calificación sigue funcionando solo con el lector OMR en el cliente.
OPENAI_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# --- Supabase server admin (requerido en Vercel para exámenes anulados / retake) ---
# Supabase → Settings → API → service_role (secreta). NO uses la anon key aquí.
SUPABASE_SERVICE_ROLE_KEY=

# --- Visión CaliFacil (públicas; se inyectan en el build del cliente) ---
# Por defecto TODA la visión está apagada (OMR local en segundos).
# Activar solo lo que necesites:
# NEXT_PUBLIC_CALIFACIL_VISION_ON_LIVE_COMMIT=true
# NEXT_PUBLIC_CALIFACIL_VISION_ON_FINAL=true
# NEXT_PUBLIC_CALIFACIL_VISION_ON_AMBIGUOUS=true
# NEXT_PUBLIC_CALIFACIL_VISION_ON_SAME_COLUMN=true
# NEXT_PUBLIC_CALIFACIL_VISION_ON_LOW_RESOLVED=true
